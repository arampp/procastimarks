# Copy this file to .env and fill in the values.
# .env is listed in .gitignore and must never be committed.

# Required: authentication secret embedded in the bookmarklet.
# Use a long, random string, e.g.: openssl rand -hex 32
API_KEY=change-me-to-a-long-random-secret

# Optional: log level filter (default: info)
# RUST_LOG=debug
