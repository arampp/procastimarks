// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/rust
{
	"name": "Rust",
	// Build from the local Dockerfile so we can bake in shell-history setup.
	"build": {
		"dockerfile": "Dockerfile"
	},
	"features": {
		"ghcr.io/devcontainers-extra/features/neovim-apt-get:1": {},
		"ghcr.io/devcontainer-community/devcontainer-features/delta:1": {
			"version": "latest"
		},
		"ghcr.io/devcontainer-community/devcontainer-features/opencode.ai:1": {
			"version": "latest"
		},
		"ghcr.io/devcontainers/features/github-cli:1": {
			"installDirectlyFromGitHubRelease": true,
			"version": "latest"
		}
	},
	// Forward the host SSH agent (Bitwarden) into the container so SSH keys are available,
	// and mount ~/.ssh so hostname aliases in ~/.ssh/config resolve correctly.
	"mounts": [
		"source=${localEnv:SSH_AUTH_SOCK},target=/tmp/ssh-agent.sock,type=bind",
		"source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,type=bind",
		"source=devcontainer-cargo-cache-${devcontainerId},target=/usr/local/cargo,type=volume",
		// Persist shell history across container rebuilds.
		"source=devcontainer-shell-history-${devcontainerId},target=/commandhistory,type=volume"
	],
	"remoteEnv": {
		"SSH_AUTH_SOCK": "/tmp/ssh-agent.sock",
		"EDITOR": "nvim",
		"VISUAL": "nvim"
	},
	// Fix volume ownership on Linux hosts where the host UID/GID may differ
	// from the container user (as recommended by the VS Code docs).
	// and set zsh as the default login shell.
	"postCreateCommand": "sudo chown -R $(whoami) /commandhistory && sudo chsh -s $(which zsh) $(whoami)",
	"customizations": {
		"vscode": {
			"settings": {
				"terminal.integrated.defaultProfile.linux": "zsh"
			},
			"extensions": [
				"asciidoctor.asciidoctor-vscode",
				"streetsidesoftware.code-spell-checker",
				"fill-labs.dependi",
				"yzhang.markdown-all-in-one",
				"shd101wyy.markdown-preview-enhanced",
				"DavidAnson.vscode-markdownlint",
				"jebbs.plantuml",
				"rust-lang.rust-analyzer",
				"tamasfe.even-better-toml",
				"vadimcn.vscode-lldb"
			]
		}
	}
	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},
	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],
	// Use 'postCreateCommand' to run commands after the container is created.
	// "postCreateCommand": "rustc --version",
	// Configure tool-specific properties.
	// "customizations": {},
	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}